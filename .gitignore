# Build output
/bin/
/dist/
/tmp/
/.tmp/

# Stray root-level deps (e.g. when a sub-package install resolves up here)
/node_modules/

# Local env / secrets / local DB
.env
*.db

# Frontend build output / deps (Phase 4)
/web/node_modules/

# Go
*.test
*.out
*.exe
__debug_bin*

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.swp

/certs/

# Claude Code harness state (worktrees, local settings) - never commit
.claude/

# Internal project + AI-workflow docs - kept local, never published.
# Listed file-by-pattern instead of as a bare `docs/` so the canonical
# OpenAPI spec at docs/openapi.yaml can be force-included with a negation
# below (git ignores file-level negations under a directory-excluded path).
docs/*
!docs/openapi.yaml
design/

# Playwright e2e outputs
/web/test-results/
/web/playwright-report/
/web/.playwright/
