{
  "name": "burrow-e2e-full",
  "version": "0.0.0",
  "private": true,
  "description": "test-only — full Playwright e2e suite for the 4-container harness. Never deploy.",
  "scripts": {
    "test": "playwright test",
    "test:mock": "playwright test --project=mock",
    "test:postgres": "playwright test --project=postgres",
    "test:headed": "playwright test --headed --workers=1",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "typescript": "~6.0.2"
  }
}
