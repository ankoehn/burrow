# test-only — never deploy this shape.
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/burrow ./cmd/client && \
    CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/upstream ./test/integration/upstream

FROM alpine:3.20
RUN apk add --no-cache curl bash
RUN adduser -D -u 65532 burrow && mkdir -p /run/burrow /etc/burrow && chown burrow:burrow /run/burrow /etc/burrow
USER 65532
COPY --from=build /out/burrow /usr/local/bin/burrow
COPY --from=build /out/upstream /usr/local/bin/upstream
COPY test/integration/full/burrow-multi.yaml /etc/burrow/burrow.yaml
COPY test/integration/full/entrypoints/client-multi.sh /usr/local/bin/client-multi.sh
ENTRYPOINT ["/usr/local/bin/client-multi.sh"]
