# test-only — never deploy this shape.
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/burrow ./cmd/client && \
    CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/upstream ./test/harness/upstream

FROM alpine:3.20
RUN apk add --no-cache curl bash
RUN adduser -D -u 65532 burrow && mkdir -p /run/burrow && chown burrow:burrow /run/burrow
USER 65532
COPY --from=build /out/burrow /usr/local/bin/burrow
COPY --from=build /out/upstream /usr/local/bin/upstream
COPY test/harness/entrypoints/client-tcp.sh /usr/local/bin/client-tcp.sh
ENV BURROW_RELAY=relay.test.local:7000 \
    UPSTREAM_ADDR=127.0.0.1:8082 \
    BURROW_REMOTE_PORT=9002 \
    BURROW_TUNNEL_NAME=tcp-echo
ENTRYPOINT ["/usr/local/bin/client-tcp.sh"]
