# test-only — never deploy this shape.
FROM golang:1.26-alpine AS build
WORKDIR /src
COPY . .
RUN CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o /out/burrow ./cmd/client

FROM alpine:3.20
RUN apk add --no-cache curl bash ca-certificates
RUN adduser -D -u 65532 burrow && mkdir -p /run/burrow && chown burrow:burrow /run/burrow
USER 65532
COPY --from=build /out/burrow /usr/local/bin/burrow
COPY test/harness/entrypoints/client-ai.sh /usr/local/bin/client-ai.sh
COPY test/harness/certs/ca.crt /usr/local/share/ca-certificates/burrow-test-ca.crt
ENV BURROW_RELAY=relay.test.local:7000 \
    BURROW_UPSTREAM=mockoai:8081 \
    BURROW_REMOTE_PORT=9001 \
    BURROW_TUNNEL_NAME=ai
ENTRYPOINT ["/usr/local/bin/client-ai.sh"]
